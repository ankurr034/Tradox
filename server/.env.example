PORT=8000
FRONTEND_URL=http://localhost:5173
MONGODB_URI=mongodb://localhost:27017/nexusai

# Authentication
JWT_SECRET=your_jwt_secret_here

# Gemini AI API Key (Get from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Razorpay Keys (Get from Razorpay Dashboard)
RAZORPAY_KEY_ID=rzp_test_yourkeyid
RAZORPAY_KEY_SECRET=yourkeysecrethere

# Blockchain Configuration
POLYGON_RPC_URL=your_polygon_rpc_url_here
PRIVATE_KEY=your_private_key_here
PREDICTION_LOGGER_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512

# Broker Credentials (Optional for real execution integration)
BROKER_API_KEY=your_broker_api_key
BROKER_SECRET=your_broker_secret
REDIRECT_URI=http://localhost:8000/api/broker/callback
CLIENT_ID=your_client_id
CLIENT_SECRET=your_client_secret
WS_URL=wss://api.broker.com/stream
